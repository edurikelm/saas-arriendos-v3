      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Geist:wght@400;500;700&family=JetBrains+Mono:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n  @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n  :root {\n    --background: oklch(0.2046 0 0);\n    --foreground: oklch(0.9219 0 0);\n    --primary: oklch(0.6231 0.1880 259.8145);\n    --primary-foreground: oklch(1.0000 0 0);\n    --accent: oklch(0.3791 0.1378 265.5222);\n    --accent-foreground: oklch(0.8823 0.0571 254.1284);\n    --border: oklch(0.3715 0 0);\n    --card: oklch(0.2686 0 0);\n    --muted: oklch(0.2393 0 0);\n    --muted-foreground: oklch(0.7155 0 0);\n  }\n\n  body {\n    background-color: var(--background);\n    color: var(--foreground);\n    font-family: 'Geist', sans-serif;\n    margin: 0;\n  }\n\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n  .glow-cyan {\n    box-shadow: 0 0 40px -10px oklch(0.7 0.2 200 / 0.3);\n  }\n  .glow-purple {\n    box-shadow: 0 0 60px -15px var(--primary);\n  }\n\n  .text-mask-video {\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n    position: relative;\n  }\n\n  .glass {\n    background: rgba(255, 255, 255, 0.03);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n  }\n\n  .no-scrollbar::-webkit-scrollbar { display: none; }\n  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n</style>\n\n<div class=\"relative min-h-screen overflow-x-hidden\" data-kid=\"1\">\n  \n  <nav class=\"sticky top-0 z-50 flex h-16 w-full items-center justify-between border-b border-white/5 bg-background/50 px-8 backdrop-blur-md\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2\" data-kid=\"3\">\n      <div class=\"flex size-8 items-center justify-center rounded-lg bg-primary font-bold text-white\" data-kid=\"4\">R</div>\n      <span class=\"text-xl font-bold tracking-tight\" data-kid=\"5\">RentalPro</span>\n    </div>\n    <div class=\"hidden items-center gap-8 text-sm font-medium text-muted-foreground md:flex\" data-kid=\"6\">\n      <a href=\"#\" class=\"transition-colors hover:text-white\" data-kid=\"7\">Funciones</a>\n      <a href=\"#\" class=\"transition-colors hover:text-white\" data-kid=\"8\">Precios</a>\n      <a href=\"#\" class=\"transition-colors hover:text-white\" data-kid=\"9\">Mercado Pago</a>\n      <a href=\"#\" class=\"transition-colors hover:text-white\" data-kid=\"10\">Soporte</a>\n    </div>\n    <div class=\"flex items-center gap-4\" data-kid=\"11\">\n      <button class=\"text-sm font-medium hover:text-primary transition-colors\" data-kid=\"12\">Entrar</button>\n      <button class=\"rounded-full bg-primary px-5 py-2 text-sm font-bold text-white glow-purple hover:scale-105 transition-transform\" data-kid=\"13\">\n        Empieza ahora\n      </button>\n    </div>\n  </nav>\n\n  \n  <section class=\"relative flex min-h-[90vh] flex-col items-center justify-center px-4 pt-20 text-center\" data-kid=\"14\">\n    <div class=\"absolute inset-0 -z-10 overflow-hidden\" data-kid=\"15\">\n      <div class=\"absolute left-1/2 top-1/4 size-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/20 blur-[120px]\" data-kid=\"16\"></div>\n      <div class=\"absolute right-0 top-0 size-[400px] rounded-full bg-accent/10 blur-[100px]\" data-kid=\"17\"></div>\n    </div>\n\n    <div class=\"max-w-4xl space-y-8\" data-kid=\"18\">\n      <div class=\"inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-xs font-medium uppercase tracking-widest text-primary\" data-kid=\"19\">\n        <span class=\"relative flex h-2 w-2\" data-kid=\"20\">\n          <span class=\"absolute inline-flex h-full w-full animate-ping rounded-full bg-primary opacity-75\" data-kid=\"21\"></span>\n          <span class=\"relative inline-flex h-2 w-2 rounded-full bg-primary\" data-kid=\"22\"></span>\n        </span>\n        Nuevo: Gestión Mensual Avanzada\n      </div>\n      \n      <h1 class=\"text-6xl font-bold leading-[1.1] tracking-tighter sm:text-7xl lg:text-8xl\" data-kid=\"23\">\n        Control <span class=\"text-mask-video bg-cover bg-center\" style=\"background-image: url('https://images.pexels.com/videos/32259560/apartment-architecture-background-business-32259560.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200');\" data-kid=\"24\">Total</span> <br data-kid=\"25\"> \n        en tus arriendos\n      </h1>\n      \n      <p class=\"mx-auto max-w-2xl text-lg text-muted-foreground sm:text-xl\" data-kid=\"26\">\n        Gestiona propiedades, reservas y pagos con la precisión de un panel de control de élite. Sin fricción, sin errores, 100% automático.\n      </p>\n\n      <div class=\"flex flex-wrap items-center justify-center gap-4\" data-kid=\"27\">\n        <button class=\"rounded-full bg-white px-8 py-4 text-lg font-bold text-black hover:bg-white/90 transition-all\" data-kid=\"28\">\n          Prueba Gratis 14 días\n        </button>\n        <button class=\"glass flex items-center gap-2 rounded-full px-8 py-4 text-lg font-bold hover:bg-white/10 transition-all\" data-kid=\"29\">\n          <i class=\"ti ti-player-play-filled\" data-kid=\"30\"></i> Ver Demo\n        </button>\n      </div>\n    </div>\n\n    \n    <div class=\"hero-mockup relative mt-20 w-full max-w-6xl px-4\" data-kid=\"31\">\n      <div class=\"relative overflow-hidden rounded-2xl border border-white/10 bg-[#0a0a0a] shadow-2xl glow-cyan\" data-kid=\"32\">\n        <div class=\"flex items-center gap-2 border-b border-white/5 bg-white/5 px-4 py-3\" data-kid=\"33\">\n          <div class=\"flex gap-1.5\" data-kid=\"34\">\n            <div class=\"size-2.5 rounded-full bg-white/20\" data-kid=\"35\"></div>\n            <div class=\"size-2.5 rounded-full bg-white/20\" data-kid=\"36\"></div>\n            <div class=\"size-2.5 rounded-full bg-white/20\" data-kid=\"37\"></div>\n          </div>\n          <div class=\"ml-4 flex h-6 w-64 items-center rounded-md bg-white/5 px-3 text-[10px] text-muted-foreground\" data-kid=\"38\">\n            rentalpro.app/dashboard/timeline\n          </div>\n        </div>\n        <div class=\"p-6\" data-kid=\"39\">\n          \n          <div class=\"grid grid-cols-4 gap-4 mb-6\" data-kid=\"40\">\n             <div class=\"rounded-xl border border-white/5 bg-white/2 px-4 py-3\" data-kid=\"41\">\n               <div class=\"text-[10px] font-medium text-muted-foreground uppercase tracking-wider mb-1\" data-kid=\"42\">Ingresos Hoy</div>\n               <div class=\"text-2xl font-bold\" data-kid=\"43\">$1.240.000</div>\n               <div class=\"text-[10px] text-primary mt-1\" data-kid=\"44\">+12% vs ayer</div>\n             </div>\n             <div class=\"rounded-xl border border-white/5 bg-white/2 px-4 py-3\" data-kid=\"45\">\n               <div class=\"text-[10px] font-medium text-muted-foreground uppercase tracking-wider mb-1\" data-kid=\"46\">Ocupación</div>\n               <div class=\"text-2xl font-bold\" data-kid=\"47\">94%</div>\n               <div class=\"text-[10px] text-primary mt-1\" data-kid=\"48\">Capacidad máxima</div>\n             </div>\n             <div class=\"rounded-xl border border-white/5 bg-white/2 px-4 py-3\" data-kid=\"49\">\n               <div class=\"text-[10px] font-medium text-muted-foreground uppercase tracking-wider mb-1\" data-kid=\"50\">Pagos Pendientes</div>\n               <div class=\"text-2xl font-bold\" data-kid=\"51\">14</div>\n               <div class=\"text-[10px] text-yellow-500 mt-1\" data-kid=\"52\">Requiere atención</div>\n             </div>\n             <div class=\"rounded-xl border border-white/5 bg-white/2 px-4 py-3\" data-kid=\"53\">\n               <div class=\"text-[10px] font-medium text-muted-foreground uppercase tracking-wider mb-1\" data-kid=\"54\">Check-ins Hoy</div>\n               <div class=\"text-2xl font-bold\" data-kid=\"55\">8</div>\n               <div class=\"text-[10px] text-green-500 mt-1\" data-kid=\"56\">Todo coordinado</div>\n             </div>\n          </div>\n          <img src=\"https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&w=1200&q=80&fit=crop\" alt=\"Dashboard Financials\" class=\"w-full rounded-xl border border-white/10 opacity-80\" decoding=\"async\" loading=\"lazy\" data-kid=\"57\">\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"sticky-reel relative min-h-screen py-32\" data-kid=\"58\">\n    <div class=\"mx-auto flex max-w-7xl px-8\" data-kid=\"59\">\n      \n      <div class=\"sticky top-40 h-fit w-1/2 pr-20\" data-kid=\"60\">\n        <h2 class=\"font-mono text-primary text-sm uppercase tracking-widest mb-4\" data-kid=\"61\">Eficiencia Máxima</h2>\n        <div class=\"reel-step opacity-100\" id=\"step-1\" data-kid=\"62\">\n          <h3 class=\"text-5xl font-bold mb-6\" data-kid=\"63\">Timeline Inteligente</h3>\n          <p class=\"text-xl text-muted-foreground\" data-kid=\"64\">\n            Visualiza tu disponibilidad en un carril único. Gestiona cientos de unidades sin perder el hilo. Arrastra y suelta para ajustar fechas.\n          </p>\n        </div>\n        <div class=\"reel-step opacity-30 mt-32\" id=\"step-2\" data-kid=\"65\">\n          <h3 class=\"text-5xl font-bold mb-6\" data-kid=\"66\">Cobros en Piloto Automático</h3>\n          <p class=\"text-xl text-muted-foreground\" data-kid=\"67\">\n            Integración nativa con Mercado Pago. Links que se generan solos, vencimientos que se notifican y webhooks que actualizan tus saldos al instante.\n          </p>\n        </div>\n        <div class=\"reel-step opacity-30 mt-32\" id=\"step-3\" data-kid=\"68\">\n          <h3 class=\"text-5xl font-bold mb-6\" data-kid=\"69\">Reportes de otro nivel</h3>\n          <p class=\"text-xl text-muted-foreground\" data-kid=\"70\">\n            No más Excel. Descarga reportes financieros detallados por propiedad, tipo de cobro o periodo con un solo clic.\n          </p>\n        </div>\n      </div>\n\n      \n      <div class=\"w-1/2 space-y-40\" data-kid=\"71\">\n        <div class=\"reel-image h-[500px] overflow-hidden rounded-2xl border border-white/10 glass p-4\" data-kid=\"72\">\n           <div class=\"h-full w-full rounded-xl bg-white/5 flex items-center justify-center border border-white/10\" data-kid=\"73\">\n              <i class=\"ti ti-calendar-days text-8xl text-primary/40\" data-kid=\"74\"></i>\n           </div>\n        </div>\n        <div class=\"reel-image h-[500px] overflow-hidden rounded-2xl border border-white/10 glass p-4\" data-kid=\"75\">\n           <div class=\"h-full w-full rounded-xl bg-white/5 flex items-center justify-center border border-white/10\" data-kid=\"76\">\n              <i class=\"ti ti-credit-card text-8xl text-accent/40\" data-kid=\"77\"></i>\n           </div>\n        </div>\n        <div class=\"reel-image h-[500px] overflow-hidden rounded-2xl border border-white/10 glass\" data-kid=\"78\">\n           <img src=\"https://images.unsplash.com/photo-1666875753105-c63a6f3bdc86?auto=format&w=1200&q=80&fit=crop\" alt=\"Reports\" class=\"h-full w-full object-cover opacity-60\" decoding=\"async\" loading=\"lazy\" data-kid=\"79\">\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 bg-white/2\" data-kid=\"80\">\n    <div class=\"mx-auto max-w-7xl px-8\" data-kid=\"81\">\n      <div class=\"grid lg:grid-cols-2 gap-20 items-center\" data-kid=\"82\">\n        <div class=\"relative h-[500px]\" data-kid=\"83\">\n           \n           <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cubes.svg\" class=\"absolute -top-10 -left-10 size-40 opacity-10\" style=\"color: oklch(0.7 0.2 260);\" data-kid=\"84\">\n           \n           <div class=\"absolute top-10 left-10 size-64 glass rounded-3xl z-20 p-8 shadow-2xl animate-bounce\" style=\"animation-duration: 4s;\" data-kid=\"85\">\n              <div class=\"text-xs font-mono text-primary mb-2\" data-kid=\"86\">MODO DIARIO</div>\n              <div class=\"text-3xl font-bold mb-4\" data-kid=\"87\">Check-in rápido</div>\n              <div class=\"text-muted-foreground text-sm\" data-kid=\"88\">Tarifas dinámicas por noche con cálculo automático de impuestos.</div>\n           </div>\n\n           <div class=\"absolute bottom-10 right-10 size-64 bg-primary/20 backdrop-blur-3xl rounded-3xl z-10 p-8 border border-primary/30 shadow-2xl\" data-kid=\"89\">\n              <div class=\"text-xs font-mono text-accent mb-2\" data-kid=\"90\">MODO MENSUAL</div>\n              <div class=\"text-3xl font-bold mb-4\" data-kid=\"91\">Arriendo fijo</div>\n              <div class=\"text-muted-foreground text-sm\" data-kid=\"92\">Contratos largos con generación de N cuotas automáticas y vencimientos mensuales.</div>\n           </div>\n        </div>\n        <div class=\"space-y-6\" data-kid=\"93\">\n          <h2 class=\"text-5xl font-bold tracking-tight\" data-kid=\"94\">Billing híbrido. <br data-kid=\"95\"> Sin excepciones.</h2>\n          <p class=\"text-xl text-muted-foreground\" data-kid=\"96\">\n            Ya sea un turista por 3 noches o un arrendatario por 2 años, RentalPro adapta el motor financiero. Cambia entre cobros diarios y mensuales con un switch.\n          </p>\n          <ul class=\"space-y-4 pt-4\" data-kid=\"97\">\n            <li class=\"flex items-center gap-3 text-lg\" data-kid=\"98\">\n              <i class=\"ti ti-circle-check-filled text-primary\" data-kid=\"99\"></i> Descuentos mensuales automáticos\n            </li>\n            <li class=\"flex items-center gap-3 text-lg\" data-kid=\"100\">\n              <i class=\"ti ti-circle-check-filled text-primary\" data-kid=\"101\"></i> Generación masiva de boletas\n            </li>\n            <li class=\"flex items-center gap-3 text-lg\" data-kid=\"102\">\n              <i class=\"ti ti-circle-check-filled text-primary\" data-kid=\"103\"></i> Tracking de saldos por cuota\n            </li>\n          </ul>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 overflow-hidden\" data-kid=\"104\">\n    <div class=\"mx-auto max-w-7xl px-8 mb-12\" data-kid=\"105\">\n      <h2 class=\"text-center text-4xl font-bold\" data-kid=\"106\">La mejor vista del mercado</h2>\n    </div>\n    <div class=\"flex gap-8 px-8 no-scrollbar overflow-x-auto pb-10\" data-kid=\"107\">\n      \n      <div class=\"flex-none w-[1600px] rounded-3xl border border-white/5 bg-white/2 p-8 glass\" data-kid=\"108\">\n         <div class=\"grid grid-cols-1 gap-6\" data-kid=\"109\">\n            <div class=\"flex items-center gap-4\" data-kid=\"110\">\n               <div class=\"w-40 shrink-0 font-bold text-sm\" data-kid=\"111\">Depto 101</div>\n               <div class=\"flex-1 h-8 rounded-full bg-primary/20 border border-primary/40 relative\" data-kid=\"112\">\n                  <div class=\"absolute left-1/4 w-1/3 h-full bg-primary rounded-full flex items-center px-4 text-[10px] font-bold\" data-kid=\"113\">RESERVA #1204 - Juan Pérez</div>\n               </div>\n            </div>\n            <div class=\"flex items-center gap-4\" data-kid=\"114\">\n               <div class=\"w-40 shrink-0 font-bold text-sm\" data-kid=\"115\">Cabaña Alpina</div>\n               <div class=\"flex-1 h-8 rounded-full bg-accent/20 border border-accent/40 relative\" data-kid=\"116\">\n                  <div class=\"absolute left-10 w-1/4 h-full bg-accent rounded-full flex items-center px-4 text-[10px] font-bold text-black\" data-kid=\"117\">BLOQUEO AIRBNB</div>\n                  <div class=\"absolute right-20 w-1/5 h-full bg-primary/60 rounded-full flex items-center px-4 text-[10px] font-bold\" data-kid=\"118\">RESERVA #1210</div>\n               </div>\n            </div>\n            <div class=\"flex items-center gap-4\" data-kid=\"119\">\n               <div class=\"w-40 shrink-0 font-bold text-sm\" data-kid=\"120\">Loft Moderno</div>\n               <div class=\"flex-1 h-8 rounded-full bg-white/5 border border-white/10\" data-kid=\"121\"></div>\n            </div>\n            \n            <div class=\"flex items-center gap-4 opacity-50\" data-kid=\"122\">\n               <div class=\"w-40 shrink-0 font-bold text-sm\" data-kid=\"123\">Casa de Playa</div>\n               <div class=\"flex-1 h-8 rounded-full bg-white/5 border border-white/10\" data-kid=\"124\"></div>\n            </div>\n         </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"px-4 py-40\" data-kid=\"125\">\n    <div class=\"mx-auto max-w-5xl rounded-[40px] bg-white px-8 py-24 text-center text-black shadow-[0_0_100px_-20px_white]\" data-kid=\"126\">\n      <h2 class=\"text-5xl font-bold leading-tight sm:text-6xl\" data-kid=\"127\">\n        Lleva tu gestión <br data-kid=\"128\"> al siguiente nivel.\n      </h2>\n      <p class=\"mx-auto mt-8 max-w-xl text-xl font-medium opacity-60\" data-kid=\"129\">\n        Empieza hoy con el plan gratuito de 3 propiedades. Sin tarjetas, sin compromiso, solo eficiencia.\n      </p>\n      <div class=\"mt-12 flex flex-col items-center justify-center gap-6 sm:flex-row\" data-kid=\"130\">\n        <button class=\"rounded-full bg-black px-10 py-5 text-xl font-bold text-white hover:scale-105 transition-transform\" data-kid=\"131\">\n          Crear cuenta gratis\n        </button>\n        <button class=\"rounded-full border border-black/10 px-10 py-5 text-xl font-bold hover:bg-black/5 transition-all\" data-kid=\"132\">\n          Hablar con ventas\n        </button>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"border-t border-white/5 py-20 px-8\" data-kid=\"133\">\n    <div class=\"mx-auto max-w-7xl flex flex-col md:flex-row justify-between gap-12\" data-kid=\"134\">\n      <div class=\"space-y-4\" data-kid=\"135\">\n        <div class=\"flex items-center gap-2\" data-kid=\"136\">\n          <div class=\"flex size-6 items-center justify-center rounded bg-primary font-bold text-white text-xs\" data-kid=\"137\">R</div>\n          <span class=\"text-lg font-bold tracking-tight\" data-kid=\"138\">RentalPro</span>\n        </div>\n        <p class=\"text-sm text-muted-foreground max-w-xs\" data-kid=\"139\">\n          La plataforma definitiva para dueños de propiedades exigentes.\n        </p>\n      </div>\n      <div class=\"grid grid-cols-2 sm:grid-cols-3 gap-12\" data-kid=\"140\">\n        <div class=\"space-y-4\" data-kid=\"141\">\n          <h4 class=\"text-sm font-bold uppercase tracking-widest\" data-kid=\"142\">Producto</h4>\n          <ul class=\"space-y-2 text-sm text-muted-foreground\" data-kid=\"143\">\n            <li data-kid=\"144\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"145\">Funciones</a></li>\n            <li data-kid=\"146\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"147\">Precios</a></li>\n            <li data-kid=\"148\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"149\">Integraciones</a></li>\n          </ul>\n        </div>\n        <div class=\"space-y-4\" data-kid=\"150\">\n          <h4 class=\"text-sm font-bold uppercase tracking-widest\" data-kid=\"151\">Compañía</h4>\n          <ul class=\"space-y-2 text-sm text-muted-foreground\" data-kid=\"152\">\n            <li data-kid=\"153\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"154\">Sobre nosotros</a></li>\n            <li data-kid=\"155\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"156\">Blog</a></li>\n            <li data-kid=\"157\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"158\">Contacto</a></li>\n          </ul>\n        </div>\n        <div class=\"space-y-4\" data-kid=\"159\">\n          <h4 class=\"text-sm font-bold uppercase tracking-widest\" data-kid=\"160\">Legal</h4>\n          <ul class=\"space-y-2 text-sm text-muted-foreground\" data-kid=\"161\">\n            <li data-kid=\"162\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"163\">Privacidad</a></li>\n            <li data-kid=\"164\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"165\">Términos</a></li>\n          </ul>\n        </div>\n      </div>\n    </div>\n    <div class=\"mx-auto max-w-7xl mt-20 pt-8 border-t border-white/5 text-center text-xs text-muted-foreground\" data-kid=\"166\">\n      © 2025 RentalPro Technologies S.A. Todos los derechos reservados.\n    </div>\n  </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"167\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"168\"></script>\n<script type=\"module\" data-kid=\"169\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  \n  // Initialize Lenis\n  const lenis = new Lenis();\n  function raf(time) {\n    lenis.raf(time);\n    requestAnimationFrame(raf);\n  }\n  requestAnimationFrame(raf);\n\n  // Initialize GSAP\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Hero Animation (Dehisce)\n  gsap.from(\".hero-mockup\", {\n    y: 100,\n    opacity: 0,\n    rotateX: -10,\n    duration: 1.8,\n    ease: \"expo.out\",\n    delay: 0.5\n  });\n\n  // Sticky Reel Scroll Logic\n  const steps = document.querySelectorAll('.reel-step');\n  steps.forEach((step, i) => {\n    gsap.to(step, {\n      opacity: 1,\n      scrollTrigger: {\n        trigger: step,\n        start: \"top center\",\n        end: \"bottom center\",\n        scrub: true,\n        onEnter: () => updateActiveStep(i),\n        onEnterBack: () => updateActiveStep(i),\n      }\n    });\n  });\n\n  function updateActiveStep(index) {\n    steps.forEach((s, i) => {\n      s.classList.toggle('opacity-100', i === index);\n      s.classList.toggle('opacity-30', i !== index);\n    });\n  }\n\n  // Horizontal Scroll parallax (subtle)\n  gsap.to(\".flex-none\", {\n    x: -100,\n    scrollTrigger: {\n      trigger: \".no-scrollbar\",\n      start: \"top bottom\",\n      end: \"bottom top\",\n      scrub: true\n    }\n  });\n</script>",
