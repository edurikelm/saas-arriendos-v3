      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --primary: oklch(0.6231 0.1880 259.8145);\n    --primary-foreground: oklch(1.0000 0 0);\n    --secondary: #ff9a8b; /* Soft coral accent from inspiration */\n    --beige: #fdf8f4;\n    --font-sans: 'Inter', sans-serif;\n    --font-serif: 'Source Serif 4', serif;\n  }\n\n  body {\n    font-family: var(--font-sans);\n    color: oklch(0.3211 0 0);\n    overflow-x: hidden;\n    margin: 0;\n  }\n\n  .font-serif { font-family: var(--font-serif); }\n  \n  .bg-primary { background-color: var(--primary); }\n  .text-primary { color: var(--primary); }\n  .border-primary { border-color: var(--primary); }\n  \n  .bg-beige { background-color: var(--beige); }\n  \n  .glass {\n    background: rgba(255, 255, 255, 0.7);\n    backdrop-filter: blur(10px);\n    border: 1px solid rgba(255, 255, 255, 0.3);\n  }\n\n  .polaroid {\n    background: white;\n    padding: 1rem 1rem 3rem 1rem;\n    box-shadow: 0 10px 30px -10px rgba(0,0,0,0.1);\n    border: 1px solid rgba(0,0,0,0.05);\n  }\n\n  .marquee {\n    display: flex;\n    overflow: hidden;\n    user-select: none;\n    gap: 4rem;\n  }\n\n  .marquee-content {\n    flex-shrink: 0;\n    display: flex;\n    justify-content: space-around;\n    min-width: 100%;\n    gap: 4rem;\n    animation: scroll 30s linear infinite;\n  }\n\n  @keyframes scroll {\n    from { transform: translateX(0); }\n    to { transform: translateX(-100%); }\n  }\n\n  .floating {\n    animation: floating 3s ease-in-out infinite;\n  }\n\n  @keyframes floating {\n    0%, 100% { transform: translateY(0); }\n    50% { transform: translateY(-10px); }\n  }\n\n  .hero-gradient {\n    background: radial-gradient(circle at 70% 30%, oklch(0.6231 0.1880 259.8145 / 0.1) 0%, transparent 70%);\n  }\n</style>\n\n<div class=\"relative bg-white\" data-kid=\"1\">\n  \n  <header class=\"fixed top-0 w-full z-50 glass border-b border-black/5\" data-kid=\"2\">\n    <div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2\" data-kid=\"4\">\n        <div class=\"size-10 rounded-xl bg-primary flex items-center justify-center shadow-lg shadow-primary/20\" data-kid=\"5\">\n          <span class=\"text-white font-bold text-xl\" data-kid=\"6\">R</span>\n        </div>\n        <span class=\"font-bold text-2xl tracking-tight\" data-kid=\"7\">RentalPro</span>\n      </div>\n      \n      <nav class=\"hidden md:flex items-center gap-8 text-sm font-medium\" data-kid=\"8\">\n        <a href=\"#\" class=\"hover:text-primary transition-colors\" data-kid=\"9\">Características</a>\n        <a href=\"#\" class=\"hover:text-primary transition-colors\" data-kid=\"10\">Precios</a>\n        <a href=\"#\" class=\"hover:text-primary transition-colors\" data-kid=\"11\">Mercado Pago</a>\n      </nav>\n\n      <div class=\"flex items-center gap-4\" data-kid=\"12\">\n        <a href=\"#\" class=\"text-sm font-semibold hover:text-primary transition-colors\" data-kid=\"13\">Entrar</a>\n        <a href=\"#\" class=\"bg-primary text-white px-6 py-2.5 rounded-full text-sm font-semibold shadow-lg shadow-primary/20 hover:scale-105 transition-transform\" data-kid=\"14\">Empieza Gratis</a>\n      </div>\n    </div>\n  </header>\n\n  \n  <section class=\"pt-40 pb-24 px-6 relative hero-gradient\" data-kid=\"15\">\n    <div class=\"max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center\" data-kid=\"16\">\n      <div class=\"hero-text opacity-0\" data-kid=\"17\">\n        <div class=\"inline-flex items-center gap-2 px-4 py-2 rounded-full bg-secondary/10 text-[#e67e71] text-xs font-bold mb-6 border border-secondary/20\" data-kid=\"18\">\n          <i class=\"ti ti-sparkles\" data-kid=\"19\"></i> NUEVA VERSIÓN 2.0\n        </div>\n        <h1 class=\"text-6xl font-bold leading-[1.1] mb-8\" data-kid=\"20\">\n          Gestiona tus arriendos como un <span class=\"text-primary\" data-kid=\"21\">vecino amigable</span>, no como un robot.\n        </h1>\n        <p class=\"text-xl text-gray-600 mb-10 max-w-lg leading-relaxed\" data-kid=\"22\">\n          Controla tus propiedades, sincroniza calendarios y cobra automáticamente con Mercado Pago. Todo en un solo lugar, diseñado para personas reales.\n        </p>\n        <div class=\"flex flex-col sm:flex-row gap-4\" data-kid=\"23\">\n          <button class=\"bg-primary text-white px-10 py-4 rounded-full text-lg font-bold shadow-2xl shadow-primary/30 hover:scale-105 transition-transform flex items-center justify-center gap-2\" data-kid=\"24\">\n            Pruébalo gratis hoy <i class=\"ti ti-arrow-right\" data-kid=\"25\"></i>\n          </button>\n          <button class=\"px-10 py-4 rounded-full text-lg font-bold border-2 border-black/5 hover:bg-black/5 transition-colors\" data-kid=\"26\">\n            Ver demo en vivo\n          </button>\n        </div>\n        <div class=\"mt-8 flex items-center gap-4 text-sm text-gray-500\" data-kid=\"27\">\n          <div class=\"flex -space-x-2\" data-kid=\"28\">\n            <img src=\"https://i.pravatar.cc/40?u=1\" class=\"size-8 rounded-full border-2 border-white\" alt=\"User\" data-kid=\"29\">\n            <img src=\"https://i.pravatar.cc/40?u=2\" class=\"size-8 rounded-full border-2 border-white\" alt=\"User\" data-kid=\"30\">\n            <img src=\"https://i.pravatar.cc/40?u=3\" class=\"size-8 rounded-full border-2 border-white\" alt=\"User\" data-kid=\"31\">\n          </div>\n          <span data-kid=\"32\">Unido por +200 administradores este mes</span>\n        </div>\n      </div>\n\n      <div class=\"relative hero-visual opacity-0\" data-kid=\"33\">\n        \n        <div class=\"absolute -top-20 -right-20 size-80 bg-primary/5 rounded-full blur-3xl\" data-kid=\"34\"></div>\n        <div class=\"absolute -bottom-20 -left-20 size-80 bg-secondary/5 rounded-full blur-3xl\" data-kid=\"35\"></div>\n        \n        \n        <div class=\"relative z-10 grid grid-cols-12 gap-4\" data-kid=\"36\">\n          <div class=\"col-span-8 floating\" data-kid=\"37\">\n            <div class=\"rounded-3xl overflow-hidden shadow-2xl border-8 border-white\" data-kid=\"38\">\n              <img src=\"https://images.unsplash.com/photo-1744782351841-9cc6b86a5add?auto=format&w=800&q=80&fit=crop\" class=\"w-full h-auto\" alt=\"Property Manager\" decoding=\"async\" loading=\"lazy\" data-kid=\"39\">\n            </div>\n          </div>\n          \n          <div class=\"col-span-5 col-start-7 -mt-40 floating\" style=\"animation-delay: -1.5s\" data-kid=\"40\">\n            <div class=\"glass p-5 rounded-2xl shadow-2xl border border-white/50\" data-kid=\"41\">\n              <div class=\"flex items-center gap-3 mb-4\" data-kid=\"42\">\n                <div class=\"size-8 rounded-full bg-green-100 flex items-center justify-center text-green-600\" data-kid=\"43\">\n                  <i class=\"ti ti-check\" data-kid=\"44\"></i>\n                </div>\n                <div data-kid=\"45\">\n                  <div class=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest\" data-kid=\"46\">MERCADO PAGO</div>\n                  <div class=\"text-sm font-bold\" data-kid=\"47\">Pago Recibido</div>\n                </div>\n              </div>\n              <div class=\"text-2xl font-bold mb-1\" data-kid=\"48\">$450.000</div>\n              <div class=\"text-xs text-gray-500\" data-kid=\"49\">Departamento 402 - Juan Pérez</div>\n            </div>\n          </div>\n\n          <div class=\"col-span-7 col-start-2 -mt-10 floating\" style=\"animation-delay: -0.8s\" data-kid=\"50\">\n            <div class=\"bg-white p-4 rounded-2xl shadow-xl border border-black/5\" data-kid=\"51\">\n              <div class=\"text-xs font-bold mb-3 flex items-center justify-between\" data-kid=\"52\">\n                <span data-kid=\"53\">Disponibilidad</span>\n                <span class=\"text-primary\" data-kid=\"54\">Junio 2025</span>\n              </div>\n              <div class=\"grid grid-cols-7 gap-1\" data-kid=\"55\">\n                <div class=\"h-1 rounded-full bg-primary/10\" data-kid=\"56\"></div>\n                <div class=\"h-1 rounded-full bg-primary/40\" data-kid=\"57\"></div>\n                <div class=\"h-1 rounded-full bg-primary\" data-kid=\"58\"></div>\n                <div class=\"h-1 rounded-full bg-primary\" data-kid=\"59\"></div>\n                <div class=\"h-1 rounded-full bg-primary/20\" data-kid=\"60\"></div>\n                <div class=\"h-1 rounded-full bg-gray-100\" data-kid=\"61\"></div>\n                <div class=\"h-1 rounded-full bg-gray-100\" data-kid=\"62\"></div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-12 border-y border-black/5 bg-white overflow-hidden\" data-kid=\"63\">\n    <div class=\"marquee\" data-kid=\"64\">\n      <div class=\"marquee-content items-center\" data-kid=\"65\">\n        <img src=\"https://upload.wikimedia.org/wikipedia/commons/b/b5/Mercado_Pago_logo.svg\" class=\"h-8 opacity-40 grayscale hover:grayscale-0 transition-all\" alt=\"Mercado Pago\" decoding=\"async\" loading=\"lazy\" data-kid=\"66\">\n        <span class=\"text-xl font-bold text-gray-300\" data-kid=\"67\">AIRBNB</span>\n        <span class=\"text-xl font-bold text-gray-300\" data-kid=\"68\">BOOKING.COM</span>\n        <span class=\"text-xl font-bold text-gray-300\" data-kid=\"69\">VRBO</span>\n        <span class=\"text-xl font-bold text-gray-300\" data-kid=\"70\">EXPEDIA</span>\n        <img src=\"https://upload.wikimedia.org/wikipedia/commons/b/b5/Mercado_Pago_logo.svg\" class=\"h-8 opacity-40 grayscale\" alt=\"Mercado Pago\" decoding=\"async\" loading=\"lazy\" data-kid=\"71\">\n        <span class=\"text-xl font-bold text-gray-300\" data-kid=\"72\">PROPERTY PRO</span>\n      </div>\n      \n      <div class=\"marquee-content items-center\" data-kid=\"73\">\n        <img src=\"https://upload.wikimedia.org/wikipedia/commons/b/b5/Mercado_Pago_logo.svg\" class=\"h-8 opacity-40 grayscale\" alt=\"Mercado Pago\" decoding=\"async\" loading=\"lazy\" data-kid=\"74\">\n        <span class=\"text-xl font-bold text-gray-300\" data-kid=\"75\">AIRBNB</span>\n        <span class=\"text-xl font-bold text-gray-300\" data-kid=\"76\">BOOKING.COM</span>\n        <span class=\"text-xl font-bold text-gray-300\" data-kid=\"77\">VRBO</span>\n        <span class=\"text-xl font-bold text-gray-300\" data-kid=\"78\">EXPEDIA</span>\n        <img src=\"https://upload.wikimedia.org/wikipedia/commons/b/b5/Mercado_Pago_logo.svg\" class=\"h-8 opacity-40 grayscale\" alt=\"Mercado Pago\" decoding=\"async\" loading=\"lazy\" data-kid=\"79\">\n        <span class=\"text-xl font-bold text-gray-300\" data-kid=\"80\">PROPERTY PRO</span>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-6 bg-beige\" data-kid=\"81\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"82\">\n      <div class=\"text-center mb-20\" data-kid=\"83\">\n        <h2 class=\"text-4xl font-bold mb-6\" data-kid=\"84\">Todo lo que necesitas para crecer</h2>\n        <p class=\"text-gray-600 max-w-2xl mx-auto text-lg\" data-kid=\"85\">\n          Olvida los Excels complejos. Hemos diseñado RentalPro para que sea intuitivo desde el primer clic.\n        </p>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-12 gap-6 bento-grid\" data-kid=\"86\">\n        \n        <div class=\"md:col-span-8 bg-white rounded-[2rem] p-10 shadow-sm border border-black/5 relative overflow-hidden bento-card opacity-0\" data-kid=\"87\">\n          <div class=\"relative z-10 max-w-md\" data-kid=\"88\">\n            <div class=\"size-12 rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-6\" data-kid=\"89\">\n              <i class=\"ti ti-calendar-event text-2xl\" data-kid=\"90\"></i>\n            </div>\n            <h3 class=\"text-2xl font-bold mb-4\" data-kid=\"91\">Calendario Timeline Maestro</h3>\n            <p class=\"text-gray-600 mb-8\" data-kid=\"92\">\n              Visualiza todas tus propiedades en una sola línea de tiempo. Arrastra y suelta para mover reservas y gestiona la disponibilidad en tiempo real.\n            </p>\n          </div>\n          \n          <div class=\"absolute -right-20 bottom-0 w-3/5 hidden lg:block\" data-kid=\"93\">\n            <div class=\"bg-beige p-6 rounded-tl-3xl border-l border-t border-black/5 shadow-2xl\" data-kid=\"94\">\n              <div class=\"flex gap-4 mb-4\" data-kid=\"95\">\n                <div class=\"w-24 h-4 bg-gray-200 rounded\" data-kid=\"96\"></div>\n                <div class=\"flex-1 h-4 bg-primary/20 rounded\" data-kid=\"97\"></div>\n              </div>\n              <div class=\"flex gap-4 mb-4\" data-kid=\"98\">\n                <div class=\"w-24 h-4 bg-gray-200 rounded\" data-kid=\"99\"></div>\n                <div class=\"flex-1 h-4 bg-primary rounded\" data-kid=\"100\"></div>\n              </div>\n              <div class=\"flex gap-4\" data-kid=\"101\">\n                <div class=\"w-24 h-4 bg-gray-200 rounded\" data-kid=\"102\"></div>\n                <div class=\"flex-1 h-4 bg-gray-100 rounded\" data-kid=\"103\"></div>\n              </div>\n            </div>\n          </div>\n          \n          \n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/burning-dot.svg\" class=\"absolute top-0 right-0 size-64 opacity-[0.03]\" style=\"color: var(--primary);\" data-kid=\"104\">\n        </div>\n\n        \n        <div class=\"md:col-span-4 bg-white rounded-[2rem] p-10 shadow-sm border border-black/5 bento-card opacity-0\" data-kid=\"105\">\n          <div class=\"size-12 rounded-2xl bg-secondary/10 text-secondary flex items-center justify-center mb-6\" data-kid=\"106\">\n            <i class=\"ti ti-receipt text-2xl\" data-kid=\"107\"></i>\n          </div>\n          <h3 class=\"text-2xl font-bold mb-4\" data-kid=\"108\">Cobros Flexibles</h3>\n          <p class=\"text-gray-600\" data-kid=\"109\">\n            Soporta arriendos diarios y mensuales sin esfuerzo. Generamos las cuotas automáticamente para estadías largas.\n          </p>\n        </div>\n\n        \n        <div class=\"md:col-span-4 bg-white rounded-[2rem] p-10 shadow-sm border border-black/5 bento-card opacity-0\" data-kid=\"110\">\n          <div class=\"size-12 rounded-2xl bg-green-100 text-green-600 flex items-center justify-center mb-6\" data-kid=\"111\">\n            <i class=\"ti ti-chart-bar text-2xl\" data-kid=\"112\"></i>\n          </div>\n          <h3 class=\"text-2xl font-bold mb-4\" data-kid=\"113\">Finanzas Claras</h3>\n          <p class=\"text-gray-600\" data-kid=\"114\">\n            Reportes detallados de ingresos pagados y pendientes. Sé exactamente cuánto estás ganando por cada propiedad.\n          </p>\n        </div>\n\n        \n        <div class=\"md:col-span-8 bg-primary text-white rounded-[2rem] p-10 shadow-2xl shadow-primary/20 relative overflow-hidden bento-card opacity-0\" data-kid=\"115\">\n          <div class=\"relative z-10 flex flex-col md:flex-row items-center gap-10\" data-kid=\"116\">\n            <div class=\"flex-1\" data-kid=\"117\">\n              <div class=\"size-12 rounded-2xl bg-white/20 flex items-center justify-center mb-6\" data-kid=\"118\">\n                <i class=\"ti ti-credit-card text-2xl text-white\" data-kid=\"119\"></i>\n              </div>\n              <h3 class=\"text-2xl font-bold mb-4\" data-kid=\"120\">Integración con Mercado Pago</h3>\n              <p class=\"text-white/80\" data-kid=\"121\">\n                Envía links de pago automáticos y recibe notificaciones cuando tu huésped pague. Tu dinero, directo a tu cuenta, sin intermediarios.\n              </p>\n            </div>\n            <div class=\"flex-shrink-0\" data-kid=\"122\">\n              <div class=\"bg-white p-6 rounded-3xl text-gray-900 shadow-2xl\" data-kid=\"123\">\n                <img src=\"https://upload.wikimedia.org/wikipedia/commons/b/b5/Mercado_Pago_logo.svg\" class=\"h-6 mb-4\" alt=\"MP\" data-kid=\"124\">\n                <div class=\"space-y-3\" data-kid=\"125\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"126\">\n                    <div class=\"size-2 rounded-full bg-green-500\" data-kid=\"127\"></div>\n                    <span class=\"text-xs font-bold\" data-kid=\"128\">Checkout Pro activo</span>\n                  </div>\n                  <div class=\"w-40 h-8 bg-gray-100 rounded-lg\" data-kid=\"129\"></div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-6\" data-kid=\"130\">\n    <div class=\"max-w-5xl mx-auto text-center\" data-kid=\"131\">\n      <h2 class=\"text-4xl font-bold mb-20 italic font-serif\" data-kid=\"132\">El flujo perfecto de pago</h2>\n      \n      <div class=\"relative flex flex-col md:flex-row justify-between items-start gap-12\" data-kid=\"133\">\n        \n        <div class=\"hidden md:block absolute top-12 left-0 w-full h-0.5 border-t-2 border-dashed border-primary/20 -z-10\" data-kid=\"134\"></div>\n        \n        <div class=\"step-card bg-white p-8 rounded-3xl border border-black/5 shadow-xl flex-1 text-left relative opacity-0\" data-kid=\"135\">\n          <div class=\"size-10 rounded-full bg-primary text-white flex items-center justify-center font-bold mb-6 -mt-12 shadow-lg\" data-kid=\"136\">1</div>\n          <h4 class=\"font-bold text-lg mb-2\" data-kid=\"137\">Reserva Creada</h4>\n          <p class=\"text-sm text-gray-500\" data-kid=\"138\">Agregas la reserva al calendario en segundos.</p>\n        </div>\n\n        <div class=\"step-card bg-white p-8 rounded-3xl border border-black/5 shadow-xl flex-1 text-left relative opacity-0\" data-kid=\"139\">\n          <div class=\"size-10 rounded-full bg-primary text-white flex items-center justify-center font-bold mb-6 -mt-12 shadow-lg\" data-kid=\"140\">2</div>\n          <h4 class=\"font-bold text-lg mb-2\" data-kid=\"141\">Link Generado</h4>\n          <p class=\"text-sm text-gray-500\" data-kid=\"142\">RentalPro crea un link de Mercado Pago personalizado.</p>\n        </div>\n\n        <div class=\"step-card bg-white p-8 rounded-3xl border border-black/5 shadow-xl flex-1 text-left relative opacity-0\" data-kid=\"143\">\n          <div class=\"size-10 rounded-full bg-primary text-white flex items-center justify-center font-bold mb-6 -mt-12 shadow-lg\" data-kid=\"144\">3</div>\n          <h4 class=\"font-bold text-lg mb-2\" data-kid=\"145\">Confirmación</h4>\n          <p class=\"text-sm text-gray-500\" data-kid=\"146\">El pago se registra solo y la reserva se confirma.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-6 bg-[#fdf8f4]\" data-kid=\"147\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"148\">\n      <h2 class=\"text-center text-4xl font-bold mb-24 font-serif\" data-kid=\"149\">Historias de anfitriones felices</h2>\n      \n      <div class=\"grid md:grid-cols-3 gap-12\" data-kid=\"150\">\n        <div class=\"testimonial-card opacity-0 translate-y-10\" data-kid=\"151\">\n          <div class=\"polaroid transform -rotate-2 hover:rotate-0 transition-transform duration-500\" data-kid=\"152\">\n            <div class=\"flex gap-1 mb-4\" data-kid=\"153\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/star.svg\" class=\"size-4\" data-kid=\"154\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/star.svg\" class=\"size-4\" data-kid=\"155\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/star.svg\" class=\"size-4\" data-kid=\"156\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/star.svg\" class=\"size-4\" data-kid=\"157\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/star.svg\" class=\"size-4\" data-kid=\"158\">\n            </div>\n            <p class=\"font-serif text-lg leading-relaxed mb-6 italic\" data-kid=\"159\">\n              \"Antes perdía horas cada semana coordinando reservas por WhatsApp. Con RentalPro tengo todo bajo control.\"\n            </p>\n            <div class=\"flex items-center gap-4\" data-kid=\"160\">\n              <img src=\"https://i.pravatar.cc/100?u=maria\" class=\"size-10 rounded-full grayscale\" alt=\"Maria\" data-kid=\"161\">\n              <div data-kid=\"162\">\n                <div class=\"font-bold text-sm\" data-kid=\"163\">María Elena</div>\n                <div class=\"text-xs text-gray-400\" data-kid=\"164\">Dueña de 4 cabañas</div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"testimonial-card opacity-0 translate-y-10\" data-kid=\"165\">\n          <div class=\"polaroid transform rotate-1 hover:rotate-0 transition-transform duration-500\" data-kid=\"166\">\n            <div class=\"flex gap-1 mb-4\" data-kid=\"167\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/star.svg\" class=\"size-4\" data-kid=\"168\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/star.svg\" class=\"size-4\" data-kid=\"169\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/star.svg\" class=\"size-4\" data-kid=\"170\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/star.svg\" class=\"size-4\" data-kid=\"171\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/star.svg\" class=\"size-4\" data-kid=\"172\">\n            </div>\n            <p class=\"font-serif text-lg leading-relaxed mb-6 italic\" data-kid=\"173\">\n              \"La integración con Mercado Pago es magia. Ya no tengo que pedir comprobantes, el sistema lo hace por mí.\"\n            </p>\n            <div class=\"flex items-center gap-4\" data-kid=\"174\">\n              <img src=\"https://i.pravatar.cc/100?u=carlos\" class=\"size-10 rounded-full grayscale\" alt=\"Carlos\" data-kid=\"175\">\n              <div data-kid=\"176\">\n                <div class=\"font-bold text-sm\" data-kid=\"177\">Carlos Ruiz</div>\n                <div class=\"text-xs text-gray-400\" data-kid=\"178\">Administrador de departamentos</div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"testimonial-card opacity-0 translate-y-10\" data-kid=\"179\">\n          <div class=\"polaroid transform -rotate-1 hover:rotate-0 transition-transform duration-500\" data-kid=\"180\">\n            <div class=\"flex gap-1 mb-4\" data-kid=\"181\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/star.svg\" class=\"size-4\" data-kid=\"182\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/star.svg\" class=\"size-4\" data-kid=\"183\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/star.svg\" class=\"size-4\" data-kid=\"184\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/star.svg\" class=\"size-4\" data-kid=\"185\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/star.svg\" class=\"size-4\" data-kid=\"186\">\n            </div>\n            <p class=\"font-serif text-lg leading-relaxed mb-6 italic\" data-kid=\"187\">\n              \"Sencillo, rápido y confiable. Mis huéspedes están felices porque reciben confirmaciones profesionales.\"\n            </p>\n            <div class=\"flex items-center gap-4\" data-kid=\"188\">\n              <img src=\"https://i.pravatar.cc/100?u=lucia\" class=\"size-10 rounded-full grayscale\" alt=\"Lucia\" data-kid=\"189\">\n              <div data-kid=\"190\">\n                <div class=\"font-bold text-sm\" data-kid=\"191\">Lucía Méndez</div>\n                <div class=\"text-xs text-gray-400\" data-kid=\"192\">Propietaria independiente</div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-6 bg-white\" data-kid=\"193\">\n    <div class=\"max-w-5xl mx-auto\" data-kid=\"194\">\n      <div class=\"bg-primary rounded-[3rem] p-16 text-center text-white shadow-2xl shadow-primary/40 relative overflow-hidden\" data-kid=\"195\">\n        <div class=\"absolute inset-0 bg-gradient-to-br from-primary via-primary to-secondary/30\" data-kid=\"196\"></div>\n        <div class=\"relative z-10\" data-kid=\"197\">\n          <h2 class=\"text-5xl font-bold mb-8\" data-kid=\"198\">¿Listo para retomar el control?</h2>\n          <p class=\"text-xl text-white/80 mb-12 max-w-2xl mx-auto leading-relaxed\" data-kid=\"199\">\n            Únete a los cientos de propietarios que ya están ahorrando tiempo y aumentando sus ingresos con RentalPro.\n          </p>\n          <div class=\"flex flex-col sm:flex-row gap-4 justify-center\" data-kid=\"200\">\n            <button class=\"bg-white text-primary px-12 py-5 rounded-full text-xl font-bold shadow-2xl hover:scale-105 transition-transform\" data-kid=\"201\">\n              Empieza gratis hoy\n            </button>\n            <button class=\"bg-white/10 text-white px-12 py-5 rounded-full text-xl font-bold backdrop-blur-sm border border-white/20 hover:bg-white/20 transition-colors\" data-kid=\"202\">\n              Hablemos por WhatsApp\n            </button>\n          </div>\n          <p class=\"mt-8 text-sm text-white/60\" data-kid=\"203\">\n            Sin tarjetas de crédito · Sin compromisos · Cancela cuando quieras\n          </p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"py-20 px-6 border-t border-black/5 bg-white\" data-kid=\"204\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"205\">\n      <div class=\"grid md:grid-cols-4 gap-12 mb-20\" data-kid=\"206\">\n        <div class=\"col-span-1 md:col-span-2\" data-kid=\"207\">\n          <div class=\"flex items-center gap-2 mb-6\" data-kid=\"208\">\n            <div class=\"size-8 rounded-lg bg-primary flex items-center justify-center\" data-kid=\"209\">\n              <span class=\"text-white font-bold text-sm\" data-kid=\"210\">R</span>\n            </div>\n            <span class=\"font-bold text-xl tracking-tight\" data-kid=\"211\">RentalPro</span>\n          </div>\n          <p class=\"text-gray-500 max-w-sm mb-6\" data-kid=\"212\">\n            La plataforma de gestión de arriendos más amigable del mercado chileno, integrada oficialmente con Mercado Pago.\n          </p>\n          <div class=\"flex gap-4\" data-kid=\"213\">\n            <a href=\"#\" class=\"size-10 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 hover:text-primary transition-colors border border-black/5\" data-kid=\"214\">\n              <i class=\"ti ti-brand-instagram text-xl\" data-kid=\"215\"></i>\n            </a>\n            <a href=\"#\" class=\"size-10 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 hover:text-primary transition-colors border border-black/5\" data-kid=\"216\">\n              <i class=\"ti ti-brand-linkedin text-xl\" data-kid=\"217\"></i>\n            </a>\n            <a href=\"#\" class=\"size-10 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 hover:text-primary transition-colors border border-black/5\" data-kid=\"218\">\n              <i class=\"ti ti-brand-facebook text-xl\" data-kid=\"219\"></i>\n            </a>\n          </div>\n        </div>\n        \n        <div data-kid=\"220\">\n          <h5 class=\"font-bold mb-6\" data-kid=\"221\">Producto</h5>\n          <ul class=\"space-y-4 text-sm text-gray-500\" data-kid=\"222\">\n            <li data-kid=\"223\"><a href=\"#\" class=\"hover:text-primary\" data-kid=\"224\">Funciones</a></li>\n            <li data-kid=\"225\"><a href=\"#\" class=\"hover:text-primary\" data-kid=\"226\">Mercado Pago</a></li>\n            <li data-kid=\"227\"><a href=\"#\" class=\"hover:text-primary\" data-kid=\"228\">Precios</a></li>\n            <li data-kid=\"229\"><a href=\"#\" class=\"hover:text-primary\" data-kid=\"230\">Actualizaciones</a></li>\n          </ul>\n        </div>\n\n        <div data-kid=\"231\">\n          <h5 class=\"font-bold mb-6\" data-kid=\"232\">Legal</h5>\n          <ul class=\"space-y-4 text-sm text-gray-500\" data-kid=\"233\">\n            <li data-kid=\"234\"><a href=\"#\" class=\"hover:text-primary\" data-kid=\"235\">Privacidad</a></li>\n            <li data-kid=\"236\"><a href=\"#\" class=\"hover:text-primary\" data-kid=\"237\">Términos</a></li>\n            <li data-kid=\"238\"><a href=\"#\" class=\"hover:text-primary\" data-kid=\"239\">Cookies</a></li>\n          </ul>\n        </div>\n      </div>\n      \n      <div class=\"pt-8 border-t border-black/5 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-gray-400\" data-kid=\"240\">\n        <p data-kid=\"241\">© 2025 RentalPro. Diseñado con <i class=\"ti ti-heart-filled text-primary\" data-kid=\"242\"></i> en Chile.</p>\n        <div class=\"flex gap-8\" data-kid=\"243\">\n          <a href=\"#\" class=\"hover:text-primary\" data-kid=\"244\">Política de Privacidad</a>\n          <a href=\"#\" class=\"hover:text-primary\" data-kid=\"245\">Términos de Servicio</a>\n        </div>\n      </div>\n    </div>\n  </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"246\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"247\"></script>\n<script data-kid=\"248\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  window.addEventListener('load', () => {\n    // Hero Animations\n    const tl = gsap.timeline();\n    tl.to('.hero-text', { opacity: 1, y: 0, duration: 1, ease: 'power4.out' })\n      .to('.hero-visual', { opacity: 1, scale: 1, duration: 1.2, ease: 'power3.out' }, '-=0.5');\n\n    // Bento Cards Entrance\n    gsap.to('.bento-card', {\n      scrollTrigger: {\n        trigger: '.bento-grid',\n        start: 'top 80%',\n      },\n      opacity: 1,\n      y: 0,\n      stagger: 0.1,\n      duration: 0.8,\n      ease: 'power3.out'\n    });\n\n    // Step Cards\n    gsap.to('.step-card', {\n      scrollTrigger: {\n        trigger: '.step-card',\n        start: 'top 85%',\n      },\n      opacity: 1,\n      y: 0,\n      stagger: 0.2,\n      duration: 0.8,\n      ease: 'back.out(1.7)'\n    });\n\n    // Testimonials\n    gsap.to('.testimonial-card', {\n      scrollTrigger: {\n        trigger: '.testimonial-card',\n        start: 'top 85%',\n      },\n      opacity: 1,\n      y: 0,\n      stagger: 0.2,\n      duration: 1,\n      ease: 'power2.out'\n    });\n  });\n</script>",
