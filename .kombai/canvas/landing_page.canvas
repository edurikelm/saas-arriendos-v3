      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: #ffffff;\n    color: #000000;\n    margin: 0;\n  }\n\n  .brutalist-border {\n    border: 1px solid #000000;\n  }\n\n  .brutalist-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    grid-template-rows: repeat(4, auto);\n  }\n\n  .grid-cell {\n    border-right: 1px solid #000000;\n    border-bottom: 1px solid #000000;\n    padding: 2rem;\n    position: relative;\n    overflow: hidden;\n  }\n\n  .marquee {\n    display: flex;\n    overflow: hidden;\n    white-space: nowrap;\n    border-top: 2px solid #000000;\n    border-bottom: 2px solid #000000;\n    background: #000000;\n    color: #ffffff;\n  }\n\n  .marquee-content {\n    display: flex;\n    animation: marquee 20s linear infinite;\n  }\n\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n\n  .hover-reveal-video {\n    position: fixed;\n    pointer-events: none;\n    width: 300px;\n    height: 200px;\n    z-index: 100;\n    opacity: 0;\n    transform: scale(0.8);\n    transition: opacity 0.3s ease, transform 0.3s ease;\n    border: 2px solid #000000;\n    background: #000;\n  }\n\n  .feature-item:hover ~ .hover-reveal-video {\n    opacity: 1;\n    transform: scale(1);\n  }\n\n  /* Utility to hide horizontal/vertical overflow on some cells */\n  .no-border-r { border-right: none; }\n  .no-border-b { border-bottom: none; }\n</style>\n\n<div class=\"min-h-screen\" data-kid=\"1\">\n  \n  <nav class=\"flex justify-between items-center p-6 brutalist-border no-border-r no-border-b border-t-0 border-l-0\" data-kid=\"2\">\n    <div class=\"text-2xl font-black tracking-tighter\" data-kid=\"3\">RENTALPRO</div>\n    <div class=\"flex gap-8 font-bold uppercase text-sm\" data-kid=\"4\">\n      <a href=\"#\" class=\"hover:underline\" data-kid=\"5\">Login</a>\n      <a href=\"#\" class=\"bg-black text-white px-4 py-2 hover:bg-white hover:text-black brutalist-border transition-colors\" data-kid=\"6\">Registro</a>\n    </div>\n  </nav>\n\n  \n  <section class=\"brutalist-grid brutalist-border no-border-r border-l-0\" data-kid=\"7\">\n    \n    <div class=\"grid-cell col-span-2 row-span-2 flex flex-col justify-end\" data-kid=\"8\">\n      <h1 class=\"text-7xl lg:text-8xl font-black leading-[0.9] tracking-tighter uppercase mb-4\" data-kid=\"9\">\n        Del Frenesí<br data-kid=\"10\">al Enfoque.\n      </h1>\n      <p class=\"text-xl font-bold uppercase max-w-sm\" data-kid=\"11\">La gestión de arriendos, finalmente resuelta.</p>\n    </div>\n    <div class=\"grid-cell col-span-2 row-span-3 bg-[#f5f5f5] flex items-center justify-center p-0 no-border-r\" data-kid=\"12\">\n      \n      <div class=\"w-full h-full p-8 flex flex-col gap-4\" data-kid=\"13\">\n        <div class=\"w-full h-12 brutalist-border bg-white flex items-center px-4 justify-between\" data-kid=\"14\">\n          <div class=\"flex gap-2\" data-kid=\"15\">\n            <div class=\"size-3 rounded-full brutalist-border\" data-kid=\"16\"></div>\n            <div class=\"size-3 rounded-full brutalist-border\" data-kid=\"17\"></div>\n          </div>\n          <div class=\"text-xs font-bold uppercase\" data-kid=\"18\">Dashboard / Calendario</div>\n        </div>\n        <div class=\"flex-1 brutalist-border bg-white p-4 grid grid-cols-6 gap-2\" data-kid=\"19\">\n          <div class=\"col-span-1 border-r border-black/10 flex flex-col gap-2\" data-kid=\"20\">\n            <div class=\"h-4 w-3/4 bg-black\" data-kid=\"21\"></div>\n            <div class=\"h-4 w-1/2 bg-black/20\" data-kid=\"22\"></div>\n          </div>\n          <div class=\"col-span-5 relative\" data-kid=\"23\">\n            \n            <div class=\"absolute top-4 left-4 w-32 h-6 bg-[#6366f1] brutalist-border flex items-center px-2 text-[10px] text-white font-bold\" data-kid=\"24\">RESERVA #102</div>\n            <div class=\"absolute top-12 left-40 w-48 h-6 bg-black brutalist-border flex items-center px-2 text-[10px] text-white font-bold\" data-kid=\"25\">MERCADO PAGO OK</div>\n            <div class=\"absolute top-20 left-10 w-24 h-6 bg-red-500 brutalist-border flex items-center px-2 text-[10px] text-white font-bold\" data-kid=\"26\">PENDIENTE</div>\n            \n            \n            <div class=\"w-full h-full opacity-5\" style=\"background-image: linear-gradient(#000 1px, transparent 1px), linear-gradient(90deg, #000 1px, transparent 1px); background-size: 20px 20px;\" data-kid=\"27\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    \n\n    \n    <div class=\"grid-cell\" data-kid=\"28\">\n      <div class=\"text-6xl font-black opacity-10\" data-kid=\"29\">01</div>\n      <p class=\"mt-4 font-bold uppercase text-xs\" data-kid=\"30\">Sincronización Total</p>\n    </div>\n    <div class=\"grid-cell\" data-kid=\"31\">\n      <img src=\"https://images.unsplash.com/photo-1527576539890-dfa815648363?auto=format&w=600&q=80&fit=crop\" alt=\"Architecture\" class=\"absolute inset-0 w-full h-full object-cover grayscale brightness-50\" decoding=\"async\" loading=\"lazy\" data-kid=\"32\">\n    </div>\n\n    \n    <div class=\"grid-cell flex items-center justify-center\" data-kid=\"33\">\n      <a href=\"#\" class=\"text-2xl font-black bg-black text-white p-4 w-full text-center hover:bg-white hover:text-black transition-colors brutalist-border\" data-kid=\"34\">EMPIEZA YA</a>\n    </div>\n    <div class=\"grid-cell flex flex-col justify-between\" data-kid=\"35\">\n      <i class=\"ti ti-chart-bar text-4xl\" data-kid=\"36\"></i>\n      <div class=\"font-bold uppercase text-xs\" data-kid=\"37\">Reportes Financieros Reales</div>\n    </div>\n    <div class=\"grid-cell col-span-2 no-border-r flex items-center\" data-kid=\"38\">\n      <p class=\"text-sm font-bold uppercase italic\" data-kid=\"39\">\"Antes perdía horas en Excel. Ahora solo miro mi calendario.\" — María E.</p>\n    </div>\n  </section>\n\n  \n  <section class=\"brutalist-border border-t-0 border-l-0 border-r-0 grid grid-cols-1 lg:grid-cols-2\" data-kid=\"40\">\n    <div class=\"p-12 border-r border-black flex flex-col justify-center bg-black text-white\" data-kid=\"41\">\n      <h2 class=\"text-5xl font-black uppercase mb-8\" data-kid=\"42\">El Caos Actual</h2>\n      <ul class=\"space-y-6\" data-kid=\"43\">\n        <li class=\"flex gap-4 items-start\" data-kid=\"44\">\n          <i class=\"ti ti-alert-triangle text-red-500 text-2xl\" data-kid=\"45\"></i>\n          <div data-kid=\"46\">\n            <p class=\"font-bold uppercase\" data-kid=\"47\">Sobrerreservas por falta de sincronización</p>\n            <p class=\"text-sm opacity-60\" data-kid=\"48\">WhatsApp, Airbnb y Booking no se hablan entre sí.</p>\n          </div>\n        </li>\n        <li class=\"flex gap-4 items-start\" data-kid=\"49\">\n          <i class=\"ti ti-alert-triangle text-red-500 text-2xl\" data-kid=\"50\"></i>\n          <div data-kid=\"51\">\n            <p class=\"font-bold uppercase\" data-kid=\"52\">Pagos perdidos o no identificados</p>\n            <p class=\"text-sm opacity-60\" data-kid=\"53\">¿Quién pagó qué? El banco no te da el detalle que necesitas.</p>\n          </div>\n        </li>\n      </ul>\n    </div>\n    <div class=\"p-12 flex flex-col justify-center\" data-kid=\"54\">\n      <h2 class=\"text-5xl font-black uppercase mb-8\" data-kid=\"55\">La Solución</h2>\n      <ul class=\"space-y-6\" data-kid=\"56\">\n        <li class=\"flex gap-4 items-start\" data-kid=\"57\">\n          <i class=\"ti ti-circle-check-filled text-green-500 text-2xl\" data-kid=\"58\"></i>\n          <div data-kid=\"59\">\n            <p class=\"font-bold uppercase\" data-kid=\"60\">Un solo Calendario Timeline</p>\n            <p class=\"text-sm text-black/60\" data-kid=\"61\">Visualiza todas tus propiedades en una sola línea de tiempo.</p>\n          </div>\n        </li>\n        <li class=\"flex gap-4 items-start\" data-kid=\"62\">\n          <i class=\"ti ti-circle-check-filled text-green-500 text-2xl\" data-kid=\"63\"></i>\n          <div data-kid=\"64\">\n            <p class=\"font-bold uppercase\" data-kid=\"65\">Integración Mercado Pago</p>\n            <p class=\"text-sm text-black/60\" data-kid=\"66\">Links de pago automáticos que actualizan tu estado al instante.</p>\n          </div>\n        </li>\n      </ul>\n    </div>\n  </section>\n\n  \n  <section class=\"relative\" data-kid=\"67\">\n    <div class=\"feature-item brutalist-border border-t-0 border-l-0 border-r-0 p-12 hover:bg-black hover:text-white transition-colors cursor-crosshair group\" data-video=\"https://videos.pexels.com/video-files/34845723/14770040_640_360_60fps.mp4\" data-kid=\"68\">\n      <div class=\"flex justify-between items-center\" data-kid=\"69\">\n        <h3 class=\"text-8xl font-black uppercase tracking-tighter\" data-kid=\"70\">Timeline</h3>\n        <i class=\"ti ti-arrow-up-right text-6xl opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"71\"></i>\n      </div>\n    </div>\n    <div class=\"feature-item brutalist-border border-t-0 border-l-0 border-r-0 p-12 hover:bg-black hover:text-white transition-colors cursor-crosshair group\" data-kid=\"72\">\n      <div class=\"flex justify-between items-center\" data-kid=\"73\">\n        <h3 class=\"text-8xl font-black uppercase tracking-tighter\" data-kid=\"74\">Cobros</h3>\n        <i class=\"ti ti-arrow-up-right text-6xl opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"75\"></i>\n      </div>\n    </div>\n    <div class=\"feature-item brutalist-border border-t-0 border-l-0 border-r-0 p-12 hover:bg-black hover:text-white transition-colors cursor-crosshair group\" data-kid=\"76\">\n      <div class=\"flex justify-between items-center\" data-kid=\"77\">\n        <h3 class=\"text-8xl font-black uppercase tracking-tighter\" data-kid=\"78\">Reportes</h3>\n        <i class=\"ti ti-arrow-up-right text-6xl opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"79\"></i>\n      </div>\n    </div>\n\n    \n    <div id=\"video-reveal\" class=\"hover-reveal-video\" data-kid=\"80\">\n      <video id=\"feature-video\" src muted loop playsinline poster=\"https://images.pexels.com/videos/34845723/editing-editing-software-premiere-pro-video-editing-34845723.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=400&w=600\" class=\"w-full h-full object-cover\" data-kid=\"81\"></video>\n    </div>\n  </section>\n\n  \n  <section class=\"p-12\" data-kid=\"82\">\n    <div class=\"mb-12 flex justify-between items-end\" data-kid=\"83\">\n      <div data-kid=\"84\">\n        <h2 class=\"text-4xl font-black uppercase\" data-kid=\"85\">Resumen Financiero</h2>\n        <p class=\"font-bold uppercase text-xs mt-2\" data-kid=\"86\">Seguimiento de ingresos diarios y mensuales</p>\n      </div>\n      <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/chart.svg\" class=\"size-20 opacity-20\" data-kid=\"87\">\n    </div>\n    <div class=\"brutalist-border overflow-x-auto\" data-kid=\"88\">\n      <table class=\"w-full text-left border-collapse\" data-kid=\"89\">\n        <thead class=\"bg-black text-white uppercase text-xs font-bold\" data-kid=\"90\">\n          <tr data-kid=\"91\">\n            <th class=\"p-4 border-r border-white/20\" data-kid=\"92\">Propiedad</th>\n            <th class=\"p-4 border-r border-white/20\" data-kid=\"93\">Periodo</th>\n            <th class=\"p-4 border-r border-white/20\" data-kid=\"94\">Tipo</th>\n            <th class=\"p-4 border-r border-white/20\" data-kid=\"95\">Monto</th>\n            <th class=\"p-4\" data-kid=\"96\">Estado</th>\n          </tr>\n        </thead>\n        <tbody class=\"text-sm font-bold uppercase\" data-kid=\"97\">\n          <tr class=\"border-b border-black\" data-kid=\"98\">\n            <td class=\"p-4 border-r border-black\" data-kid=\"99\">Apto. Mirador 01</td>\n            <td class=\"p-4 border-r border-black\" data-kid=\"100\">20 Jun - 25 Jun</td>\n            <td class=\"p-4 border-r border-black\" data-kid=\"101\">Diario</td>\n            <td class=\"p-4 border-r border-black\" data-kid=\"102\">$450.000</td>\n            <td class=\"p-4 text-green-600\" data-kid=\"103\">Completado</td>\n          </tr>\n          <tr class=\"border-b border-black\" data-kid=\"104\">\n            <td class=\"p-4 border-r border-black\" data-kid=\"105\">Studio Centro</td>\n            <td class=\"p-4 border-r border-black\" data-kid=\"106\">Junio 2025</td>\n            <td class=\"p-4 border-r border-black\" data-kid=\"107\">Mensual</td>\n            <td class=\"p-4 border-r border-black\" data-kid=\"108\">$800.000</td>\n            <td class=\"p-4 text-red-600\" data-kid=\"109\">Pendiente</td>\n          </tr>\n          <tr class=\"border-b border-black\" data-kid=\"110\">\n            <td class=\"p-4 border-r border-black\" data-kid=\"111\">Casa Playa Blanca</td>\n            <td class=\"p-4 border-r border-black\" data-kid=\"112\">15 Jun - 20 Jun</td>\n            <td class=\"p-4 border-r border-black\" data-kid=\"113\">Diario</td>\n            <td class=\"p-4 border-r border-black\" data-kid=\"114\">$1.200.000</td>\n            <td class=\"p-4 text-green-600\" data-kid=\"115\">Completado</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </section>\n\n  \n  <footer class=\"mt-12\" data-kid=\"116\">\n    <div class=\"marquee\" data-kid=\"117\">\n      <div class=\"marquee-content py-4\" data-kid=\"118\">\n        <span class=\"text-6xl font-black uppercase mx-8\" data-kid=\"119\">EMPIEZA YA</span>\n        <span class=\"text-6xl font-black uppercase mx-8\" data-kid=\"120\">EMPIEZA YA</span>\n        <span class=\"text-6xl font-black uppercase mx-8\" data-kid=\"121\">EMPIEZA YA</span>\n        <span class=\"text-6xl font-black uppercase mx-8\" data-kid=\"122\">EMPIEZA YA</span>\n        <span class=\"text-6xl font-black uppercase mx-8\" data-kid=\"123\">EMPIEZA YA</span>\n        <span class=\"text-6xl font-black uppercase mx-8\" data-kid=\"124\">EMPIEZA YA</span>\n        <span class=\"text-6xl font-black uppercase mx-8\" data-kid=\"125\">EMPIEZA YA</span>\n        <span class=\"text-6xl font-black uppercase mx-8\" data-kid=\"126\">EMPIEZA YA</span>\n      </div>\n    </div>\n    <button class=\"w-full bg-black text-white text-9xl font-black py-24 hover:bg-white hover:text-black transition-all brutalist-border border-t-0 border-l-0 border-r-0 border-b-0 uppercase tracking-tighter cursor-pointer\" data-kid=\"127\">\n      Crear Cuenta\n    </button>\n    <div class=\"p-12 flex justify-between items-center text-xs font-bold uppercase\" data-kid=\"128\">\n      <div data-kid=\"129\">© 2025 RentalPro. Brutal Efficiency.</div>\n      <div class=\"flex gap-8\" data-kid=\"130\">\n        <a href=\"#\" data-kid=\"131\">Términos</a>\n        <a href=\"#\" data-kid=\"132\">Privacidad</a>\n      </div>\n    </div>\n  </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"133\"></script>\n<script data-kid=\"134\">\n  window.addEventListener('DOMContentLoaded', () => {\n    // Grid Lines Animation\n    gsap.from(\".grid-cell\", {\n      duration: 1,\n      opacity: 0,\n      stagger: {\n        grid: [4, 4],\n        from: \"center\",\n        amount: 0.5\n      },\n      ease: \"power2.out\"\n    });\n\n    // Hover Reveal Logic\n    const reveal = document.getElementById('video-reveal');\n    const video = document.getElementById('feature-video');\n    const items = document.querySelectorAll('.feature-item');\n\n    document.addEventListener('mousemove', (e) => {\n      gsap.to(reveal, {\n        x: e.clientX + 20,\n        y: e.clientY + 20,\n        duration: 0.1\n      });\n    });\n\n    items.forEach(item => {\n      item.addEventListener('mouseenter', () => {\n        const videoSrc = item.getAttribute('data-video');\n        if (videoSrc) {\n          video.src = videoSrc;\n          video.play();\n        }\n        reveal.style.opacity = '1';\n        reveal.style.transform = 'scale(1)';\n      });\n\n      item.addEventListener('mouseleave', () => {\n        reveal.style.opacity = '0';\n        reveal.style.transform = 'scale(0.8)';\n        video.pause();\n      });\n    });\n  });\n</script>",
