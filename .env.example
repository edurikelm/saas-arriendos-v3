# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/rentalpro

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Mercado Pago OAuth (PKCE)
# Use N° de aplicación / APP_ID from Mercado Pago as client id.
MERCADOPAGO_OAUTH_CLIENT_ID=your_mercadopago_app_id
# Optional: some Mercado Pago apps using PKCE do not expose a client secret.
MERCADOPAGO_OAUTH_CLIENT_SECRET=
MERCADOPAGO_WEBHOOK_SECRET=your_webhook_secret
# Development only: lets local webhook tests continue when the MP webhook secret is not configured correctly.
MERCADOPAGO_WEBHOOK_ALLOW_INVALID_SIGNATURE=false
# Development/testing only: asks Mercado Pago OAuth for test credentials.
# Checkout Pro still uses init_point; sandbox_init_point is kept only as returned metadata.
MERCADOPAGO_OAUTH_TEST_TOKEN=false
# Optional dev fallback: enables manual access-token connection in Settings.
MP_MANUAL_TOKEN_ENABLED=false

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Encryption
ENCRYPTION_KEY=your_32_byte_base64_encoded_key_here
