generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  OWNER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum Plan {
  FREE
  PRO
}

enum PropertyType {
  HOUSE
  APARTMENT
  CABIN
  HOSTEL
  HOTEL
  OFFICE
  COMMERCIAL
}

enum BillingType {
  DAILY
  MONTHLY
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentMethod {
  MERCADO_PAGO
  CASH
  TRANSFER
}

enum PaymentType {
  RESERVATION
  EXTRA
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ReservationDocumentCategory {
  CONTRATO
  ANEXO
  INVENTARIO
  OTRO
}

enum ReservationDocumentType {
  PDF
  JPG
  PNG
  WEBP
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketCategory {
  RESERVATIONS
  PAYMENTS
  PROPERTIES
  ACCOUNT
  OTHER
}

enum IntegrationProvider {
  MERCADO_PAGO
  STRIPE
}

enum ExternalChannel {
  AIRBNB
  BOOKING_COM
  VRBO
  OTHER
}

enum ExternalBlockStatus {
  ACTIVE
  INACTIVE
}

enum NotificationType {
  RESERVATION_CREATED
  RESERVATION_CANCELLED
  PAYMENT_RECEIVED
  PAYMENT_REVERTED
  PAYMENT_REMINDER
  PAYMENT_FAILED
}

model UserProfile {
  id                         String     @id @default(cuid())
  name                       String?
  email                      String     @unique
  password                   String
  role                       UserRole   @default(OWNER)
  status                     UserStatus @default(ACTIVE)
  plan                       Plan?      @default(FREE)
  notificationsEmailEnabled  Boolean    @default(true)
  notificationsSmsEnabled    Boolean    @default(false)
  avatarUrl                  String?
  phone                      String?
  companyName                String?
  companyRut                 String?
  companyAddress             String?
  language                   String     @default("es")
  currency                   String     @default("CLP")
  timezone                   String     @default("America/Santiago")
  createdAt                  DateTime   @default(now())

  properties      Property[]
  clients         ReservationClient[]
  reservations    Reservation[]
  supportTickets  SupportTicket[]
  supportMessages SupportMessage[]

  adminNotes   AdminNote[]      @relation("AdminNotes")
  ownerNotes   AdminNote[]      @relation("OwnerNotes")
  adminActions AdminActionLog[] @relation("AdminActions")
  externalCalendars ExternalCalendar[]
  notifications    Notification[]
  notificationReads NotificationRead[]
  passwordResetTokens PasswordResetToken[]
}

model Notification {
  id              String           @id @default(cuid())
  notificationKey String           @unique
  userId          String
  type            NotificationType
  title           String
  body            String
  link            String?
  createdAt       DateTime         @default(now())
  deliveredAt     DateTime?

  user  UserProfile        @relation(fields: [userId], references: [id])
  reads NotificationRead[]

  @@index([userId, createdAt])
  @@index([userId, deliveredAt])
}

model NotificationRead {
  id              String   @id @default(cuid())
  notificationId String
  userId         String
  lastReadAt     DateTime @default(now())

  notification Notification @relation(fields: [notificationId], references: [id])
  user         UserProfile  @relation(fields: [userId], references: [id])

  @@unique([notificationId, userId])
  @@index([userId])
  @@index([notificationId])
}

model SupportTicket {
  id                    String         @id @default(cuid())
  userId                String
  subject               String
  description           String
  status                TicketStatus   @default(OPEN)
  priority              TicketPriority
  category              TicketCategory
  affectedReservationId String?
  affectedPaymentId     String?
  affectedPropertyId    String?
  lastActivityAt        DateTime       @default(now())
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  user                UserProfile         @relation(fields: [userId], references: [id])
  messages            SupportMessage[]
  reads               SupportTicketRead[]
  affectedReservation Reservation?        @relation("TicketAffectedReservation", fields: [affectedReservationId], references: [id])
  affectedPayment     Payment?            @relation("TicketAffectedPayment", fields: [affectedPaymentId], references: [id])
  affectedProperty    Property?           @relation("TicketAffectedProperty", fields: [affectedPropertyId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([lastActivityAt])
  @@index([affectedReservationId])
  @@index([affectedPaymentId])
  @@index([affectedPropertyId])
}

model SupportMessage {
  id              String   @id @default(cuid())
  supportTicketId String
  authorId        String
  content         String
  createdAt       DateTime @default(now())

  supportTicket SupportTicket              @relation(fields: [supportTicketId], references: [id])
  author        UserProfile                @relation(fields: [authorId], references: [id])
  attachments   SupportMessageAttachment[]

  @@index([supportTicketId])
  @@index([authorId])
}

model SupportTicketRead {
  id         String   @id @default(cuid())
  ticketId   String
  userId     String
  lastReadAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id])

  @@unique([ticketId, userId])
  @@index([ticketId])
  @@index([userId])
}

model SupportMessageAttachment {
  id        String   @id @default(cuid())
  messageId String
  url       String
  fileName  String
  fileSize  Int
  createdAt DateTime @default(now())

  message SupportMessage @relation(fields: [messageId], references: [id])

  @@index([messageId])
}

model Property {
  id             String       @id @default(cuid())
  userId         String
  name           String
  type           PropertyType
  unitsAvailable Int          @default(1)
  dailyPrice     Decimal      @db.Decimal(10, 2)
  monthlyPrice   Decimal?     @db.Decimal(10, 2)
  currency       String       @default("CLP")
  amenities      String[]
  color          String       @default("#3B82F6")
  mainImage      String?
  images         String[]
  createdAt      DateTime     @default(now())

  user                     UserProfile     @relation(fields: [userId], references: [id])
  reservations             Reservation[]
  supportTicketsAsProperty SupportTicket[] @relation("TicketAffectedProperty")
  externalCalendars        ExternalCalendar[]
  externalBlocks           ExternalChannelBlock[]
  exportFeeds             PropertyExportFeed[]

  @@index([userId])
}

model ReservationClient {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String
  phone     String?
  rut       String?
  notes     String?
  createdAt DateTime @default(now())

  user         UserProfile   @relation(fields: [userId], references: [id])
  reservations Reservation[]

  @@unique([userId, email])
  @@index([userId])
}

model Reservation {
  id            String            @id @default(cuid())
  userId        String
  propertyId    String
  clientId      String
  startDate     DateTime
  endDate       DateTime
  billingType   BillingType
  unitsBooked   Int               @default(1)
  totalPrice    Decimal           @db.Decimal(10, 2)
  status        ReservationStatus @default(PENDING)
  bookingAirbnb Boolean           @default(false)
  notes         String?
  createdAt     DateTime          @default(now())

  user                        UserProfile           @relation(fields: [userId], references: [id])
  property                    Property              @relation(fields: [propertyId], references: [id])
  client                      ReservationClient     @relation(fields: [clientId], references: [id])
  payments                    Payment[]
  changes                     ReservationChange[]
  documents                   ReservationDocument[]
  supportTicketsAsReservation SupportTicket[]       @relation("TicketAffectedReservation")

  @@index([userId])
  @@index([propertyId])
  @@index([clientId])
  @@index([startDate])
  @@index([endDate])
}

model Payment {
  id               String        @id @default(cuid())
  reservationId    String
  paymentType      PaymentType   @default(RESERVATION)
  title            String?
  description      String?
  amount           Decimal       @db.Decimal(10, 2)
  method           PaymentMethod
  status           PaymentStatus @default(PENDING)
  mercadoPagoId    String?
  initPoint        String?
  expiresAt        DateTime?
  installmentIndex Int?
  dueDate          DateTime?
  paidAt           DateTime?
  receiptUrl       String?
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())

  /// Metadata persistida del response GET /v1/payments/{id} de Mercado Pago.
  /// Ver PRD-0004 (docs/prd/PRD-0004-mp-payment-metadata-pdf.md) y ADR-0026
  /// (docs/adr/0026-mp-payment-metadata-storage.md).
  /// Poblada por el webhook #184. Idempotencia garantizada en seam canónico.
  mpPaymentId          String?   @unique
  mpStatusDetail       String?
  mpPaymentMethodId    String?
  mpPaymentType        String?
  mpCardLastFour       String?
  mpInstallments       Int?
  mpTransactionAmount  Decimal?  @db.Decimal(10, 2)
  mpNetReceivedAmount  Decimal?  @db.Decimal(10, 2)
  mpFeeAmount          Decimal?  @db.Decimal(10, 2)
  mpDateCreated        DateTime?

  reservation             Reservation     @relation(fields: [reservationId], references: [id])
  supportTicketsAsPayment SupportTicket[] @relation("TicketAffectedPayment")

  @@index([reservationId])
  @@index([status])
  @@index([paymentType])
  @@index([dueDate])
  @@index([paidAt])
  @@index([deletedAt])
  @@index([reservationId, status])
  @@unique([mercadoPagoId])
}

model ReservationChange {
  id            String   @id @default(cuid())
  reservationId String
  field         String
  oldValue      String?
  newValue      String?
  createdAt     DateTime @default(now())

  reservation Reservation @relation(fields: [reservationId], references: [id])

  @@index([reservationId])
}

model AdminNote {
  id        String   @id @default(cuid())
  adminId   String
  ownerId   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  admin UserProfile @relation("AdminNotes", fields: [adminId], references: [id])
  owner UserProfile @relation("OwnerNotes", fields: [ownerId], references: [id])

  @@index([adminId])
  @@index([ownerId])
}

model AdminActionLog {
  id        String   @id @default(cuid())
  adminId   String
  targetId  String
  action    String
  details   String?
  createdAt DateTime @default(now())

  admin UserProfile @relation("AdminActions", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetId])
}

model UserIntegration {
  id          String              @id @default(cuid())
  userId      String
  provider    IntegrationProvider
  accessToken String?
  isActive    Boolean             @default(false)
  metadata    Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

model ReservationDocument {
  id            String                      @id @default(cuid())
  reservationId String
  category      ReservationDocumentCategory
  documentType  ReservationDocumentType
  fileName      String
  filePath      String
  fileSize      Int
  mimeType      String
  deletedAt     DateTime?
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  reservation Reservation @relation(fields: [reservationId], references: [id])

  @@index([reservationId])
  @@index([reservationId, deletedAt])
}

model ExternalCalendar {
  id            String          @id @default(cuid())
  userId        String
  propertyId    String
  channel       ExternalChannel
  name          String
  feedUrl       String
  isActive      Boolean         @default(true)
  lastSyncedAt  DateTime?
  lastSyncError String?
  lastSyncCount Int?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user     UserProfile           @relation(fields: [userId], references: [id])
  property Property              @relation(fields: [propertyId], references: [id])
  blocks   ExternalChannelBlock[]

  @@index([userId])
  @@index([propertyId])
  @@index([userId, isActive])
  @@index([propertyId, isActive])
  @@unique([userId, channel, propertyId, feedUrl])
}

model ExternalChannelBlock {
  id                 String              @id @default(cuid())
  externalCalendarId String
  propertyId         String
  externalUid        String
  startDate          DateTime
  endDate            DateTime
  summary            String?
  status             ExternalBlockStatus @default(ACTIVE)
  lastSeenAt         DateTime            @default(now())
  firstSyncedAt      DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  externalCalendar ExternalCalendar @relation(fields: [externalCalendarId], references: [id], onDelete: Cascade)
  property          Property         @relation(fields: [propertyId], references: [id])

  @@unique([externalCalendarId, externalUid])
  @@index([externalCalendarId])
  @@index([propertyId, status])
  @@index([propertyId, startDate, endDate])
  @@index([status])
}

model PropertyExportFeed {
  id             String          @id @default(cuid())
  propertyId     String
  channel        ExternalChannel
  tokenHash      String          @unique
  tokenLastFour  String
  createdAt      DateTime        @default(now())
  lastRotatedAt  DateTime        @default(now())
  isRevoked      Boolean         @default(false)
  lastFetchedAt  DateTime?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, channel])
  @@index([propertyId])
  @@index([tokenHash])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
